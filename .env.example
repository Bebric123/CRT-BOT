# Токен от @BotFather
BOT_TOKEN=

# Через запятую: telegram user id админов (узнать у @userinfobot)
ADMIN_USER_IDS=

# Опционально: начальный whitelist — id супергруппы обсуждения канала (через запятую).
# Это НЕ id канала: у канала и у «чата комментариев» разные числа. Надёжно: /add_whitelist
# в группе обсуждения или /chat_id там же (админ).
WHITELIST_CHAT_IDS=

# Путь к SQLite (создаётся автоматически)
SQLITE_PATH=data/bot.db

# Логировать отказы (1/0)
LOG_REJECTIONS=1

# Не отвечать текстом при отказе — только лог (1/0)
SILENT_REJECT=0

# Картинки: .png / .jpg в assets/images — без текста на изображении; предсказание в подписи к фото (часть того же сообщения).
# Если папка пуста — только текст (без картинки).

# Таймауты HTTP к api.telegram.org (сек.), при медленном интернете / больших фото
# TELEGRAM_CONNECT_TIMEOUT=15
# TELEGRAM_READ_TIMEOUT=45
# TELEGRAM_WRITE_TIMEOUT=180

# --- Локальная LLM: текст предсказания на рабочую неделю (дата/день недели — часовой пояс сервера) ---
# 1/true — включить HTTP-запрос к локальной модели
LOCAL_LLM_ENABLED=0
# openai — POST {BASE}/chat/completions (LM Studio, vLLM, Ollama в режиме OpenAI)
# ollama — POST {BASE}/api/chat (нативный Ollama, BASE без /v1, обычно :11434)
LOCAL_LLM_BACKEND=openai
# Пример LM Studio: http://127.0.0.1:1234/v1  |  Ollama native: http://127.0.0.1:11434
LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1
LOCAL_LLM_MODEL=llama3.2
# Если сервер требует Bearer (часто пусто локально)
LOCAL_LLM_API_KEY=
LOCAL_LLM_TIMEOUT=90
LOCAL_LLM_TEMPERATURE=0.85
LOCAL_LLM_MAX_TOKENS=768
LOCAL_LLM_MAX_OUTPUT_CHARS=2400
# Подмешать в промпт фрагмент текста поста канала (настроение)
LOCAL_LLM_INCLUDE_POST=0
# Переопределение промптов (пусто = встроенные в bot/local_llm.py)
# LOCAL_LLM_SYSTEM_PROMPT=
# LOCAL_LLM_USER_PROMPT=
