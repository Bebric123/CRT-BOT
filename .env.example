# Токен от @BotFather
BOT_TOKEN=

# Через запятую: telegram user id админов (узнать у @userinfobot)
ADMIN_USER_IDS=

# Опционально: начальный whitelist — id супергруппы обсуждения канала (через запятую).
# Это НЕ id канала: у канала и у «чата комментариев» разные числа. Надёжно: /add_whitelist
# в группе обсуждения или /chat_id там же (админ).
WHITELIST_CHAT_IDS=

# Путь к SQLite (создаётся автоматически)
SQLITE_PATH=data/bot.db

# Логировать отказы (1/0)
LOG_REJECTIONS=1

# Не отвечать текстом при отказе — только лог (1/0)
SILENT_REJECT=0

# Пауза между предсказаниями для одного пользователя (секунды). По умолчанию 3600 (1 час).
# Можно менять без перезапуска: /set_rate_limit (админ).
RATE_LIMIT_SECONDS=3600

# Кэш тредов обсуждения: пусто = in-memory процесса; иначе redis://host:6379/0.
# В docker-compose для сервиса bot задаётся REDIS_URL=redis://redis:6379/0 — персистентный Redis с AOF.
REDIS_URL=

# Макс. длина сохраняемого фрагмента текста поста в кэше треда (символы)
# DISCUSSION_SNIPPET_MAX_CHARS=2500

# --- Картинки из assets/images ---
# IMAGE_VALIDATION_ENABLED=1
# IMAGE_MAX_SIDE=900
# IMAGE_MAX_FILE_BYTES=20971520
# IMAGE_MAX_WIDTH=8192
# IMAGE_MAX_HEIGHT=8192
# SAFE_IMAGE_TIMEOUT=15
#
# Модерация: auto (по умолчанию) — Sightengine, если заданы user+secret; иначе свой URL; иначе выкл.
# IMAGE_MODERATION_PROVIDER=auto
# IMAGE_MODERATION_PROVIDER=none
# IMAGE_MODERATION_PROVIDER=sightengine
# IMAGE_MODERATION_PROVIDER=custom_url
#
# Sightengine: https://sightengine.com/ — после регистрации api_user и api_secret в дашборде
# SIGHTENGINE_API_USER=
# SIGHTENGINE_API_SECRET=
# SIGHTENGINE_MODELS=nudity-2.1
# Доп. модели (через запятую): tobacco, alcohol, recreational_drug — см. доки Sightengine
# Мат / текст на картинке: text-content-2.0 + SIGHTENGINE_TEXT_CATEGORIES + желательно SIGHTENGINE_OPT_LANG=ru
# https://sightengine.com/docs/ocr-text-moderation-in-images-2.0
# SIGHTENGINE_MODELS=nudity-2.1,text-content-2.0
# SIGHTENGINE_TEXT_CATEGORIES=sexual,insult,inappropriate,discriminatory,phone_number,email
# SIGHTENGINE_OPT_LANG=ru
# Если пусто, но заданы text-content / TEXT_CATEGORIES — по умолчанию подставится ru
# К запросу добавляется модель ocr (сырой текст на картинке) для локальной проверки русского мата; 0 — не добавлять
# SIGHTENGINE_APPEND_OCR=1
# Только эти категории ведут к отклонению картинки (пусто = любая сработавшая из text_categories)
# SIGHTENGINE_IMAGE_TEXT_REJECT_ONLY=insult,inappropriate
# SIGHTENGINE_MODELS=nudity-2.1,tobacco,alcohol
# Пороги 0…1: выше — строже (меньше допускается «риска»)
# SIGHTENGINE_MAX_RAW=0.45
# SIGHTENGINE_MAX_SEXUAL=0.55
# Кровь/ужас, самоповреждение, наркотики на картинке (Sightengine). 0 — не добавлять модели и не резать по ним.
# SIGHTENGINE_MODERATE_SEVERE=1
# При MODERATE_SEVERE=1 по умолчанию порог 0.5 для трёх моделей ниже; при =0 пороги по умолчанию 1.0 (выкл.), модели не подмешиваются, пока порог явно <1
# SIGHTENGINE_MAX_GORE_PROB=0.5
# SIGHTENGINE_MAX_SELF_HARM_PROB=0.5
# SIGHTENGINE_MAX_RECREATIONAL_DRUG_PROB=0.5
# prob алкоголя/табака: 1.0 = не фильтровать; модели задайте в SIGHTENGINE_MODELS
# SIGHTENGINE_MAX_ALCOHOL_PROB=1.0
# SIGHTENGINE_MAX_TOBACCO_PROB=1.0
#
# Свой прокси (POST multipart поле image, JSON {"safe": true} или {"ok": true})
# SAFE_IMAGE_URL=
# SAFE_IMAGE_API_KEY=

# Таймауты HTTP к api.telegram.org (сек.)
# TELEGRAM_CONNECT_TIMEOUT=15
# TELEGRAM_READ_TIMEOUT=45
# TELEGRAM_WRITE_TIMEOUT=180

# --- Модерация текста предсказания (перед отправкой) ---
# TEXT_MODERATION_ENABLED=0
# Эвристика русского мата (подстроки), до блоклиста/LLM. 0 — выключить.
# TEXT_MODERATION_RU_MAT=1
# none | regex (подстроки из TEXT_BLOCKLIST) | llm (второй запрос к той же LOCAL_LLM) | both
# TEXT_MODERATION_MODE=both
# Через запятую, без пробелов вокруг запятой внутри фразы; регистр не важен
# TEXT_BLOCKLIST=
# TEXT_MODERATION_LLM_TIMEOUT=20
# TEXT_MODERATION_LLM_MAX_TOKENS=96

# --- Локальная LLM ---
LOCAL_LLM_ENABLED=0
LOCAL_LLM_BACKEND=openai
LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1
LOCAL_LLM_MODEL=llama3.2
LOCAL_LLM_API_KEY=
LOCAL_LLM_TIMEOUT=90
LOCAL_LLM_TEMPERATURE=0.85
LOCAL_LLM_MAX_TOKENS=768
# Начальный лимит символов ответа LLM (потом хранится в SQLite, меняется /set_llm_max_chars)
LOCAL_LLM_MAX_OUTPUT_CHARS=2400
LOCAL_LLM_INCLUDE_POST=0
# LOCAL_LLM_SYSTEM_PROMPT=
# LOCAL_LLM_USER_PROMPT=
